# Sao chép thành .env và tự điền thông tin MySQL dùng chung của nhóm.
# Không đưa file .env hoặc mật khẩu lên GitHub.
NODE_ENV=development
PORT=5000
CORS_ORIGIN=http://localhost:5173
DB_HOST=your-shared-mysql-host
DB_PORT=3306
DB_USER=your-database-user
DB_PASSWORD=your-database-password
DB_NAME=rubeanora_store
AUTH_SECRET=thay-bang-chuoi-bi-mat-dai-va-ngau-nhien
FRONTEND_URL=http://localhost:5173
GOOGLE_CLIENT_ID=
SEPAY_WEBHOOK_SECRET=
SEPAY_BANK_CODE=
SEPAY_BANK_NAME=
SEPAY_ACCOUNT_NUMBER=
SEPAY_ACCOUNT_HOLDER=
SEPAY_PAYMENT_PREFIX=RBB
SEPAY_TRANSFER_CONTENT_PREFIX=
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=Rubeanora <no-reply@example.com>

