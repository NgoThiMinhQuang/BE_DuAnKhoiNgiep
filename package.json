{
  "name": "be-duankhoinghiep",
  "version": "1.0.0",
  "private": true,
  "description": "Backend API cho Du An Khoi Nghiep",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "dev": "node --watch src/server.js",
    "prestart": "node scripts/migrate.js",
