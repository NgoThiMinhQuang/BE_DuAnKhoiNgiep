    "seed:home": "node scripts/seed-home.js",
    "seed:catalog": "node scripts/seed-catalog.js",
    "seed:news": "node scripts/seed-news.js",
    "seed:customer": "node scripts/seed-customer.js",
    "seed:commerce": "node scripts/seed-commerce.js",
